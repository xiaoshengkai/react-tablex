{
  "compilerOptions": {
    "strict": false,
    "declaration": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "baseUrl": "./",
    "paths": {
      "@@/*": [".dumi/tmp/*"],
      "react-tablex": ["src"],
      "react-tablex/*": ["src/*", "*"]
    }
  },
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "include": [".dumirc.ts", "src/**/*"]
}
