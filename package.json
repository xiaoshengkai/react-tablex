{
  "name": "@xiaoshengkai/react-tablex",
  "version": "1.0.0",
  "description": "React 高性能虚拟表格表单组件库 | 专为解决大数据渲染瓶颈而设计，提供配置化表格表单开发方案，内置数据监听体系，助力快速构建复杂业务场景",
  "keywords": [
    "Component",
    "UI",
    "React",
    "TypeScript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoshengkai/react-tablex.git"
  },
  "license": "MIT",
  "author": "小盛开",
  "main": "lib/index.js",
  "module": "esm/index.js",
  "types": "esm/index.d.ts",
  "files": [
    "esm",
    "lib",
    "dist"
  ],
  "scripts": {
    "build": "father build",
    "build:watch": "father dev",
    "changelog": "standard-changelog -i docs/changelog.md",
    "dev": "dumi dev",
    "docs:build": "dumi build",
    "docs:preview": "dumi preview",
    "doctor": "father doctor",
    "prepare": "husky install && dumi setup",
    "start": "npm run dev",
    "test": "jest --coverage",
    "test:single": "jest test/other.spec.ts",
    "preversion": "npm install --force",
    "version": "father doctor && npm run build && npm run docs:build && git add -A",
    "postversion": "git push && git push --tags"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@ant-design/colors": "^7.2.1",
    "@ant-design/cssinjs": "^1.23.0",
    "@ant-design/cssinjs-utils": "^1.1.3",
    "@ant-design/fast-color": "^2.0.6",
    "@ant-design/icons": "^6.1.0",
    "ahooks": "^3.8.4",
    "async-validator": "^4.2.5",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.20",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "rc-menu": "^9.16.1",
    "rc-motion": "^2.9.5",
    "rc-table": "^7.51.1",
    "rc-tree": "^5.13.1",
    "rc-util": "^5.44.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/classnames": "2.3.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.7",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@umijs/lint": "^4.0.0",
    "@zcy/dev-proxy-middleware": "^1.1.6",
    "antd": "^5.29.3",
    "babel-plugin-import": "^1.13.8",
    "dumi": "^2.4.7",
    "dumi-theme-antd": "^0.4.2",
    "eslint": "^9.9.0",
    "father": "^4.1.0",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "jest-config": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.0.0",
    "prettier-plugin-packagejson": "^2.2.18",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "standard-changelog": "^6.0.0",
    "stylelint": "^16.8.2",
    "ts-jest": "^29.3.3",
    "ts-morph": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.2.3"
  },
  "peerDependencies": {
    "antd": "^5.29.3",
    "less": "^4.2.0",
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0",
    "typescript": "^4.2.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
